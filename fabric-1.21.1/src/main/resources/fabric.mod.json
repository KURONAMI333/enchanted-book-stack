{
  "schemaVersion": 1,
  "id": "enchantedbookstack",
  "version": "${version}",
  "name": "Enchanted Book Stack",
  "description": "Stack enchanted books into a single portable item that can nest inside shulker boxes and backpacks. 54-slot capacity, vanilla shulker-like UI, enchanted_book only. (Fabric 1.21.1).",
  "authors": ["KURONAMI"],
  "contact": {
    "homepage": "https://github.com/KURONAMI333/enchanted-book-stack",
    "issues":   "https://github.com/KURONAMI333/enchanted-book-stack/issues",
    "sources":  "https://github.com/KURONAMI333/enchanted-book-stack"
  },
  "license": "MIT",

  "environment": "*",

  "entrypoints": {
    "main":   ["com.kuronami.enchantedbookstack.EnchantedBookStackFabric"],
    "client": ["com.kuronami.enchantedbookstack.client.EnchantedBookStackFabricClient"]
  },

  "depends": {
    "fabricloader": ">=0.16",
    "fabric-api":   "*",
    "minecraft":    "~1.21.1",
    "java":         ">=21"
  }
}
